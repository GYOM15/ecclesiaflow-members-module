# ============================================================================
# EcclesiaFlow Members Module - Configuration Example
# ============================================================================
# Copy this file to src/main/resources/application.properties and update 
# with your actual values before running the application.
#
# IMPORTANT: Never commit actual credentials to version control!
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# MySQL Database Configuration
spring.datasource.url=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA/Hibernate Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=${JPA_SHOW_SQL:false}
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# JWT Secret Key (must match Auth Module configuration)
jwt.secret=${JWT_SECRET}

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================
# Default Admin User (for development only)
admin.email=${ADMIN_EMAIL}
admin.password=${ADMIN_PASSWORD}
admin.firstName=${ADMIN_FIRST_NAME}
admin.lastName=${ADMIN_LAST_NAME}

# ============================================================================
# MAIL CONFIGURATION (Gmail SMTP)
# ============================================================================
# Gmail SMTP Configuration
spring.mail.host=${MAIL_HOST}
spring.mail.port=${MAIL_PORT}
spring.mail.username=${MAIL_USERNAME}
# IMPORTANT: Use Gmail App Password, not your regular password
# Generate at: Google Account > Security > 2-Step Verification > App passwords
spring.mail.password=${MAIL_PASSWORD}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.ssl.trust=${MAIL_HOST}

# Email Configuration
ecclesiaflow.mail.from=${MAIL_FROM}
ecclesiaflow.app.name=EcclesiaFlow

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Auth Module Integration
ecclesiaflow.auth.module.base-url=${AUTH_MODULE_BASE_URL}

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Application Logging Levels
logging.level.com.ecclesiaflow.business=${LOGGING_LEVEL_ECCLESIAFLOW_BUSINESS:DEBUG}
logging.level.com.ecclesiaflow.web=${LOGGING_LEVEL_ECCLESIAFLOW_WEB:DEBUG}

# Spring Framework Logging
logging.level.org.springframework.mail=${LOGGING_LEVEL_SPRING_MAIL:DEBUG}
logging.level.org.springframework.security=${LOGGING_LEVEL_SPRING_SECURITY:DEBUG}

# Root Logging Level
logging.level.root=${LOGGING_LEVEL_ROOT:INFO}

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
spring.security.filter.order=10

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Server Port (optional - defaults to 8080)
server.port=${SERVER_PORT:8080}

# ============================================================================
# PROFILE-SPECIFIC CONFIGURATIONS
# ============================================================================
# Activate specific profiles via environment variable
spring.profiles.active=${SPRING_PROFILES_ACTIVE:dev}

# ============================================================================
# DEVELOPMENT PROFILE OVERRIDES
# ============================================================================
# Additional settings for development profile

# Dev Database (H2 for testing - uncomment if needed)
#spring.datasource.url=jdbc:h2:mem:testdb
#spring.datasource.driver-class-name=org.h2.Driver
#spring.datasource.username=sa
#spring.datasource.password=password
#spring.h2.console.enabled=${H2_CONSOLE_ENABLED:false}

# ============================================================================
# PRODUCTION NOTES
# ============================================================================
# For production deployment:
# 1. All sensitive values are loaded from environment variables (.env file)
# 2. Enable SSL/TLS for database connections
# 3. Use secure password encryption
# 4. Configure proper logging levels (set to INFO or WARN)
# 5. Set up monitoring and health checks
# 6. Ensure JWT_SECRET matches the Auth Module configuration

# ============================================================================
# API DOCUMENTATION CONFIGURATION (SpringDoc OpenAPI)
# ============================================================================
# SpringDoc OpenAPI Configuration
springdoc.api-docs.path=/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.operations-sorter=method
springdoc.show-actuator=true
springdoc.default-produces-media-type=application/json
springdoc.default-consumes-media-type=application/json

# Disable cache for development
springdoc.cache.disabled=true

# Configure paths to include in documentation
springdoc.paths-to-match=/ecclesiaflow/**

# Configure packages to scan for documentation
springdoc.packages-to-scan=com.ecclesiaflow.web.controller,com.ecclesiaflow.web.exception

# ============================================================================
# OPTIONAL CONFIGURATIONS
# ============================================================================

# Actuator Endpoints (for monitoring)
#management.endpoints.web.exposure.include=health,info,metrics
#management.endpoint.health.show-details=when-authorized

# JSON Serialization
#spring.jackson.default-property-inclusion=non_null
#spring.jackson.serialization.write-dates-as-timestamps=false

# File Upload Limits
#spring.servlet.multipart.max-file-size=10MB
#spring.servlet.multipart.max-request-size=10MB

