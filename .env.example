# =============================================================================
# ECCLESIAFLOW MEMBERS MODULE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and configure values according to your environment

# =============================================================================
# ENVIRONMENT PROFILE
# =============================================================================
SPRING_PROFILES_ACTIVE=dev

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MySQL Production
DB_HOST=localhost
DB_PORT=3306
DB_NAME=members
DB_USERNAME=ecclesiaflow
DB_PASSWORD=your-secure-database-password

# =============================================================================
# KEYCLOAK OAUTH2 CONFIGURATION
# =============================================================================
# Keycloak server URLs
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/ecclesiaflow
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/ecclesiaflow/protocol/openid-connect/certs

# =============================================================================
# ADMIN CONFIGURATION
# =============================================================================
# Default admin account (for development only)
ADMIN_EMAIL=admin@ecclesiaflow.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=EcclesiaFlow

# =============================================================================
# MAIL CONFIGURATION (Gmail SMTP)
# =============================================================================
# Gmail SMTP Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# IMPORTANT: Use Gmail App Password, not your regular password
# Generate at: Google Account > Security > 2-Step Verification > App passwords
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Auth Module Integration
AUTH_MODULE_BASE_URL=http://localhost:8081

# =============================================================================
# gRPC CONFIGURATION
# =============================================================================
# Enable gRPC communication (set to false for legacy SMTP mode)
GRPC_ENABLED=true

# gRPC Server port
GRPC_SERVER_PORT=9091
GRPC_SERVER_SHUTDOWN_TIMEOUT=30

# Auth service gRPC endpoint
GRPC_AUTH_HOST=localhost
GRPC_AUTH_PORT=9090

# Email service gRPC endpoint
GRPC_EMAIL_HOST=localhost
GRPC_EMAIL_PORT=9092
GRPC_CLIENT_SHUTDOWN_TIMEOUT=5

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_PORT=8080

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Application log level
LOGGING_LEVEL_ECCLESIAFLOW_BUSINESS=DEBUG
LOGGING_LEVEL_ECCLESIAFLOW_WEB=DEBUG
# Spring Framework log levels
LOGGING_LEVEL_SPRING_MAIL=DEBUG
LOGGING_LEVEL_SPRING_SECURITY=DEBUG
# Root log level
LOGGING_LEVEL_ROOT=INFO

# =============================================================================
# DEVELOPMENT CONFIGURATION (Dev profile only)
# =============================================================================
# H2 Console (dev only)
H2_CONSOLE_ENABLED=true
# SQL query display (dev only)
JPA_SHOW_SQL=false

# =============================================================================
# IMPORTANT NOTES
# =============================================================================
# 1. NEVER commit the .env file with real values
# 2. Use strong secrets in production (JWT_SECRET, passwords)
# 3. JWT_SECRET must match the Auth Module configuration
# 4. Use Gmail App Password for MAIL_PASSWORD (not regular password)
# 5. Configure proper logging levels for production
