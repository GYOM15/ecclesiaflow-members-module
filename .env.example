# =============================================================================
# ECCLESIAFLOW MEMBERS MODULE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and configure values for your environment.
# IMPORTANT: Never commit .env with real credentials to version control.
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION (MySQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=members_module_db
DB_USERNAME=root
DB_PASSWORD=your-database-password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# =============================================================================
# KEYCLOAK OAUTH2 CONFIGURATION
# =============================================================================
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/ecclesiaflow
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/ecclesiaflow/protocol/openid-connect/certs
KEYCLOAK_ACCOUNT_URL=http://localhost:8180/realms/ecclesiaflow/account

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
AUTH_MODULE_BASE_URL=http://localhost:8081

# =============================================================================
# gRPC CONFIGURATION
# =============================================================================
GRPC_ENABLED=true
GRPC_SERVER_PORT=9091
GRPC_SERVER_SHUTDOWN_TIMEOUT=30
GRPC_AUTH_HOST=localhost
GRPC_AUTH_PORT=9090
GRPC_CLIENT_SHUTDOWN_TIMEOUT=5
# Email service gRPC endpoint
GRPC_EMAIL_HOST=localhost
GRPC_EMAIL_PORT=9092

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_BASE_URL=http://localhost:5173

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# =============================================================================
# SCOPE VALIDATION
# =============================================================================
# Set to false in dev when Keycloak custom scopes are not configured as JWT claims.
ECCLESIAFLOW_SCOPES_ENABLED=true

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_PORT=8080
