### SECURITY - SENSITIVE FILES ###
# Environment variables (contain secrets) - NOT committed
.env.dev
.env.test
.env.prod
.env.local
.env.production
.env.staging
.env

# IMPORTANT: .env.example IS committed (template only, no real secrets)
# IMPORTANT: application*.properties ARE committed (use env vars for secrets)

